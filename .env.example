# ──────────────────────────────────────────────
# PersonalLearningPro — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Firebase (optional) ──────────────────────
# Get these from https://console.firebase.google.com
# The app will run without Firebase, but auth features will be disabled.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id

# ── OpenAI (optional) ───────────────────────
# Get your key from https://platform.openai.com
# AI features (tutor, test generation) require this.
OPENAI_API_KEY=your_openai_api_key

# ── Database (Required) ─────────────────────
# MongoDB connection string
MONGODB_URL=mongodb://localhost:27017/personal-learning-pro

# ── Session (optional) ──────────────────────
# Used to sign session cookies. Auto-generates a dev default if not set.
# MUST be set in production.
SESSION_SECRET=your_random_session_secret

# ── Cassandra / Astra DB (optional — message store) ─────────────────────────
# Download the secure-connect bundle from https://astra.datastax.com
# Leave blank to fall back to storing messages in MongoDB.
ASTRA_DB_SECURE_BUNDLE_PATH=./config/secure-connect-chat-db.zip
ASTRA_DB_APPLICATION_TOKEN=AstraCS:your_token_here
ASTRA_DB_KEYSPACE=chat

MESSAGEPAL_PORT=5002

# ── Daily.co (Required for Live Classes) ────────────────────────────────────
# Get your API key from https://dashboard.daily.co/developers
# This is needed to create rooms and generate meeting tokens for live classes.
DAILY_API_KEY=your_daily_api_key_here

# ── OpenMAIC AI Classroom (Optional) ─────────────────────────────────────────
# Integration with OpenMAIC multi-agent classroom system
# Set these if you have the arena-learning infrastructure running
OPENMAIC_INTERNAL_URL=http://localhost:3000
BRIDGE_SECRET=changeme_replace_with_output_of_openssl_rand_hex_16
USE_INICLAW=true
