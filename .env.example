# ── PersonalLearningPro — Environment Variables ──────────────────────────────
# Copy to .env and fill in values: cp .env.example .env

NODE_ENV=development
PORT=5001

# MongoDB (Required)
MONGODB_URL=mongodb://localhost:27017/eduai

# Firebase (Required for auth)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=   # base64-encoded service account JSON

# OpenAI (Required for AI features)
OPENAI_API_KEY=

# Session (Required in production)
SESSION_SECRET=                  # generate: openssl rand -hex 32

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:5001

# Email / Invite system (Required for onboarding)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=EduAI <no-reply@yourdomain.com>
APP_URL=http://localhost:5001

# Cassandra / Astra DB (Optional — falls back to MongoDB)
ASTRA_DB_SECURE_BUNDLE_PATH=./config/secure-connect-chat-db.zip
ASTRA_DB_APPLICATION_TOKEN=
ASTRA_DB_KEYSPACE=chat
MESSAGEPAL_PORT=5002

# Daily.co (Required for live classes)
DAILY_API_KEY=

# JWT (Optional — used for non-Firebase auth fallback)
JWT_SECRET=
REFRESH_SECRET=
