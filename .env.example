# ── PersonalLearningPro — Environment Variables ──────────────────────────────
# Copy to .env and fill in values: cp .env.example .env

NODE_ENV=development
PORT=5001

# ─── MongoDB (Required) ──────────────────────────────────────────────────────
# Primary database for structured data (users, tests, analytics)
# Local: mongodb://localhost:27017/eduai
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/eduai
MONGODB_URL=mongodb://localhost:27017/eduai

# ─── Firebase (Required for auth) ───────────────────────────────────────────
# Get these from Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK - base64-encoded service account JSON
# Generate: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Encode: cat serviceAccountKey.json | base64 -w 0 (Linux) or base64 -i serviceAccountKey.json (Mac)
FIREBASE_SERVICE_ACCOUNT_JSON=

# OpenAI (Required for AI features)
OPENAI_API_KEY=

# ─── Session (Required in production) ───────────────────────────────────────
# Generate a secure random string: openssl rand -hex 32
SESSION_SECRET=

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:5001

# Email / Invite system (Required for onboarding)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=EduAI <no-reply@yourdomain.com>
APP_URL=http://localhost:5001

# ─── Cassandra / Astra DB (Optional — falls back to MongoDB) ───────────────
# High-performance message storage using DataStax Astra DB
# Get credentials from: https://astra.datastax.com
# Download secure connect bundle and place in ./config/ directory
ASTRA_DB_SECURE_BUNDLE_PATH=./config/secure-connect-chat-db.zip
ASTRA_DB_APPLICATION_TOKEN=
ASTRA_DB_KEYSPACE=chat

# Alternative: Base64-encoded secure bundle (for containerized deployments)
# ASTRA_DB_SECURE_BUNDLE_B64=

# MessagePal service port (internal)
MESSAGEPAL_PORT=5002

# Daily.co (Required for live classes)
DAILY_API_KEY=

# JWT (Optional — used for non-Firebase auth fallback)
JWT_SECRET=
REFRESH_SECRET=
