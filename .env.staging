# .env.staging — staging environment
# DO NOT COMMIT THIS FILE

NODE_ENV=staging
PORT=5001

# MongoDB (Atlas staging cluster)
MONGODB_URL=mongodb+srv://<user>:<pass>@staging-cluster.mongodb.net/eduai-staging

# Firebase (staging project)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# OpenAI
OPENAI_API_KEY=

# Session
SESSION_SECRET=<generate: openssl rand -hex 32>

# CORS — staging frontend URL
CORS_ORIGIN=https://staging.yourdomain.com

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
APP_URL=https://staging.yourdomain.com

# Cassandra / Astra DB
ASTRA_DB_SECURE_BUNDLE_PATH=./config/secure-connect-chat-db.zip
ASTRA_DB_APPLICATION_TOKEN=
ASTRA_DB_KEYSPACE=chat

# Daily.co
DAILY_API_KEY=
